#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    SCRIPT_DIR="$(cd -P -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
    SCRIPT_PATH="$(readlink -- "${SCRIPT_PATH}")"
    if [[ "${SCRIPT_PATH}" != /* ]]; then
        SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_PATH}"
    fi
done

SCRIPT_DIR="$(cd -P -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
PYTHONPATH_ENTRY="${ROOT_DIR}/share/tbc-video-export/src"

if [[ -n "${PYTHONPATH:-}" ]]; then
    export PYTHONPATH="${PYTHONPATH_ENTRY}:${PYTHONPATH}"
else
    export PYTHONPATH="${PYTHONPATH_ENTRY}"
fi

export TBC_VIDEO_EXPORT_VENDOR_VERSION="@APP_VERSION@"
export TBC_VIDEO_EXPORT_VENDOR_COMMIT="@APP_COMMIT@"
export TBC_VIDEO_EXPORT_VENDOR_BRANCH="@APP_BRANCH@"
PYTHON_BIN=""
if [[ -x "${ROOT_DIR}/usr/bin/python3" ]]; then
    PYTHON_BIN="${ROOT_DIR}/usr/bin/python3"
elif [[ -x "${ROOT_DIR}/bin/python3" ]]; then
    PYTHON_BIN="${ROOT_DIR}/bin/python3"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python3)"
elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python)"
else
    echo "python3 not found in bundle or PATH; cannot start tbc-video-export." >&2
    exit 127
fi

exec "${PYTHON_BIN}" "${PYTHONPATH_ENTRY}/tbc_video_export/__main__.py" "$@"
